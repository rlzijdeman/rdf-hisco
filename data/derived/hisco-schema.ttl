    schema:codeValue 31030,
        "3-10.30"^^xsd:string ;
    schema:description "Calculates the amount of tax to be paid by individuals or businesses, according to various criteria, such as income, property, profits etc."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Tax Assessor"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/31040> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
