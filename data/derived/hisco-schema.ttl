<https://iisg.amsterdam/resource/hisco/code/hisco/01110> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/011> ;
    schema:codeValue 1110,
        "0-11.10"^^xsd:string ;
    schema:description "Conducts chemical experiments, tests and analyses to investigate chemical phenomena, to test, develop or improve materials and products and to control or develop industrial processes."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Chemist, General"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/01120> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/011> ;
    schema:codeValue 1120,
        "0-11.20"^^xsd:string ;
    schema:description "Conducts chemical experiments, tests and analyses on substances of which main element is carbon, to investigate chemical phenomena, to test, develop or improve materials and products or to control or develop industrial processes."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Organic Chemist"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/01130> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/011> ;
    schema:codeValue 1130,
        "0-11.30"^^xsd:string ;
    schema:description "Conducts chemical experiments, tests and analyses on substances free or relatively free of carbon to investigate chemical phenomena, to test, develop or improve materials and products, or to control or develop industrial processes."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Inorganic Chemist"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/01140> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/011> ;
    schema:codeValue 1140,
        "0-11.40"^^xsd:string ;
    schema:description "Conducts research into relationships between chemical and physical properties of substances to increase knowledge of physical aspects of chemical phenomena or to develop or improve materials, products or industrial processes."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Physical Chemist"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/01150> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/011> ;
    schema:codeValue 1150,
        "0-11.50"^^xsd:string ;
    schema:description "Carries out chemical tests and analyses of substances and develops and improves analytical methodology and techniques."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Analytical Chemist"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/01190> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/011> ;
    schema:codeValue 1190,
        "0-11.90"^^xsd:string ;
    schema:description "This group includes chemists not elsewhere classified, for example those who specialise in the development and technical control of the manufacture of pharmaceutical products. Pharmacologist is classified in 0-52.70 and Pharmacist in 0-67.10."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Other Chemists"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/01210> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/012> ;
    schema:codeValue 1210,
        "0-12.10"^^xsd:string ;
    schema:description "Conducts research into physical phenomena to increase scientific knowledge and to develop and improve materials, products and industrial and other processes."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Physicist, General"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/01220> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/012> ;
    schema:codeValue 1220,
        "0-12.20"^^xsd:string ;
    schema:description "Conducts research in the field of mechanics to investigate physical phenomena or to develop or improve materials, products or industrial and other processes."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Mechanics Physicist"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/01230> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/012> ;
    schema:codeValue 1230,
        "0-12.30"^^xsd:string ;
    schema:description "Conducts research into nature and effects of heat to increase scientific knowledge or to develop or improve materials, products or industrial and other processes."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Heat Physicist"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/01240> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/012> ;
    schema:codeValue 1240,
        "0-12.40"^^xsd:string ;
    schema:description "Conducts research into nature and effects of light to increase scientific knowledge or to develop or improve materials, products or industrial and other processes."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Light Physicist"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/01250> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/012> ;
    schema:codeValue 1250,
        "0-12.50"^^xsd:string ;
    schema:description "Conducts research into nature and effects of sound to increase scientific knowledge or to develop or improve materials, products or industrial and other processes."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Sound Physicist"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/01260> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/012> ;
    schema:codeValue 1260,
        "0-12.60"^^xsd:string ;
    schema:description "Conducts research into nature and properties of electricity and magnetism to increase scientific knowledge or to develop or improve materials, products or industrial and other processes."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Electricity and Magnetism Physicist"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/01270> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/012> ;
    schema:codeValue 1270,
        "0-12.70"^^xsd:string ;
    schema:description "Conducts research into nature and behaviour of electrons to increase scientific knowledge or to develop or improve materials, products or industrial or other processes."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Electronics Physicist"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/01280> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/012> ;
    schema:codeValue 1280,
        "0-12.80"^^xsd:string ;
    schema:description "Conducts research into structure and characteristics of atoms, molecules and nuclei to increase scientific knowledge or to discover practical applications of atomic, molecular and nuclear physics."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Nuclear Physicist"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/01290> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/012> ;
    schema:codeValue 1290,
        "0-12.90"^^xsd:string ;
    schema:description "This group includes physicists not elsewhere classified, for example those who conduct research into structure and properties of matter in solid state; or specialise in pure research and formulate theories based on analysis of established data to explain relationships between observed physical phenomena and to explain previously unobserved phenomena, or predict results of experiments designed to detect and measure them."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Other Physicists"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/01320> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/013> ;
    schema:codeValue 1320,
        "0-13.20"^^xsd:string ;
    schema:description "Conducts research into physical nature of earth, including its atmosphere and hydrosphere, to increase scientific knowledge and to develop practical applications in such fields as radio communications, water conservation, volcanology and mineral exploration."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Geophysical Scientist"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/01330> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/013> ;
    schema:codeValue 1330,
        "0-13.30"^^xsd:string ;
    schema:description "Conducts research into nature and history of earth's crust to increase scientific knowledge and to develop practical applications in such fields as mineral exploitation and civil engineering."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Geological Scientist"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/01340> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/013> ;
    schema:codeValue 1340,
        "0-13.40"^^xsd:string ;
    schema:description "Conducts research into physical nature and properties of the earth's atmosphere and the forces affecting it to increase scientific knowledge and to develop practical applications such as weather forecasts."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Meteorological Scientist"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/01350> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/013> ;
    schema:codeValue 1350,
        "0-13.50"^^xsd:string ;
    schema:description "Observes and interprets celestial phenomena to increase scientific knowledge and to develop practical applications in such fields as navigation and space exploration."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Astronomical Scientist"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/01390> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/013> ;
    schema:codeValue 1390,
        "0-13.90"^^xsd:string ;
    schema:description "This group includes other physical scientists not elsewhere classified, for example those who specialise in examining, analysing and classifying minerals (including gems and precious stones) or advising on the likely commercial yield from mineral deposits containing gems and precious stones."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Other Physical Scientists"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/01400> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/014> ;
    schema:codeValue 1400,
        "0-14.00"^^xsd:string ;
    schema:description "May perform any (but not all) of the occupational activities described in unit group 0-14."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Physical Science Technician, Specialisation Unknown"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/01420> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/014> ;
    schema:codeValue 1420,
        "0-14.20"^^xsd:string ;
    schema:description "Performs auxiliary technical tasks, normally under direction and supervision of chemist, in connection with pure research into chemical phenomena or applied chemical research and development work."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Chemistry Technician"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/01430> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/014> ;
    schema:codeValue 1430,
        "0-14.30"^^xsd:string ;
    schema:description "Performs auxiliary technical tasks, normally under direction of physicist, in connection with pure research into physical phenomena or applied physics research and development work."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Physics Technician"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/01490> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/014> ;
    schema:codeValue 1490,
        "0-14.90"^^xsd:string ;
    schema:description "This group includes physical science technicians not elsewhere classified, for example those who perform auxiliary technical tasks in connection with research and development work conducted by geological, geophysical meteorological and astronomic scientists."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Other Physical Science Technicians"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/02000> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/020> ;
    schema:codeValue 2000,
        "0-20.00"^^xsd:string ;
    schema:description "May perform any (but not all) of the occupational activities listed in unit groups 0-22 to 0-29."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Engineers, Specialisation Unknown"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/02120> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/021> ;
    schema:codeValue 2120,
        "0-21.20"^^xsd:string ;
    schema:description "Designs buildings and exercises general supervision over their construction. Building construction engineer is classified in 0-22.20."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Building Architect"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/02130> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/021> ;
    schema:codeValue 2130,
        "0-21.30"^^xsd:string ;
    schema:description "Plans layout and co-ordinates development of urban areas."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Town Planner"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/02140> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/021> ;
    schema:codeValue 2140,
        "0-21.40"^^xsd:string ;
    schema:description "Plans and designs aesthetic layout of land areas for such projects as parks and other recreational facilities, roads, commercial, industrial and residential sites and public buildings."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Landscape Architect"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/02210> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/022> ;
    schema:codeValue 2210,
        "0-22.10"^^xsd:string ;
    schema:description "Carries out research, designs and advises on structures such as bridges, dams, docks, roads, airports, railways, waste disposal and flood control systems and industrial and other large buildings, and plans, organises and supervises their construction, maintenance and repair."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Civil Engineer, General"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/02220> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/022> ;
    schema:codeValue 2220,
        "0-22.20"^^xsd:string ;
    schema:description "Designs structures of large buildings and plans, organises and supervises their erection, maintenance and repair."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Building Construction Engineer"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/02230> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/022> ;
    schema:codeValue 2230,
        "0-22.30"^^xsd:string ;
    schema:description "Designs highways and streets and plans, organises and supervises their construction, maintenance and repair."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Highway and Street Construction Engineer"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/02235> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/022> ;
    schema:codeValue 2235,
        "0-22.35"^^xsd:string ;
    schema:description "Designs airports and landing strips and plans, organises and supervises their construction, maintenance and repair."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Aerodrome Construction Engineer"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/02240> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/022> ;
    schema:codeValue 2240,
        "0-22.40"^^xsd:string ;
    schema:description "Designs railroads, terminals and other railway structures and plans, organises and supervises their construction, maintenance and repair."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Railway Construction Engineer"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/02245> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/022> ;
    schema:codeValue 2245,
        "0-22.45"^^xsd:string ;
    schema:description "Designs bridges and plans, organises and supervises their construction, maintenance and repair."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Bridge Construction Engineer"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/02250> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/022> ;
    schema:codeValue 2250,
        "0-22.50"^^xsd:string ;
    schema:description "Designs engineering structures and equipment related to public health and hygiene, such as are required for water-supply and waste-disposal systems, and plans, organises and supervises their construction, operation, maintenance and repair."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Sanitary Engineer"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/02255> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/022> ;
    schema:codeValue 2255,
        "0-22.55"^^xsd:string ;
    schema:description "Designs hydro-power, water supply, irrigation, inland waterways and related projects and plans, organises and supervises their construction, maintenance and repair."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Hydraulics Engineer"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/02260> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/022> ;
    schema:codeValue 2260,
        "0-22.60"^^xsd:string ;
    schema:description "Examines soils and ascertains their effect on construction work and suitability as building materials."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Soil Mechanics Engineer"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/02290> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/022> ;
    schema:codeValue 2290,
        "0-22.90"^^xsd:string ;
    schema:description "This group includes civil engineers not elsewhere classified, for example those who perform tasks similar to those of Civil engineer, general (0-22.10) but specialise in the design, construction and maintenance of tunnels, wharves, docks and harbour breakwaters, lighthouses, chimney stacks, towers and pylons; or in the dredging of harbours and ship channels."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Other Civil Engineers"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/02305> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/023> ;
    schema:codeValue 2305,
        "0-23.05"^^xsd:string ;
    schema:description "Carries out research on electrical engineering problems, designs and advises on electrical systems and equipment, and plans and supervises their development, construction, installation, operation, maintenance and repair."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Electrical Engineer, General"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/02310> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/023> ;
    schema:codeValue 2310,
        "0-23.10"^^xsd:string ;
    schema:description "Carries out research on electronics engineering problems, designs and advises on electronic devices and equipment and plans and supervises their development, construction, installation, operation, maintenance and repair."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Electronics Engineer, General"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/02320> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/023> ;
    schema:codeValue 2320,
        "0-23.20"^^xsd:string ;
    schema:description "Studies, designs and advises on electricity generating systems and plant and plans and supervises their construction, operation, maintenance and repair."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Power Generation Engineer"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/02330> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/023> ;
    schema:codeValue 2330,
        "0-23.30"^^xsd:string ;
    schema:description "Studies, designs and advises on systems and equipment for transmission and distribution of electric power and plans and supervises their development, construction, maintenance and repair."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Power Distribution and Transmission Engineer"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/02340> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/023> ;
    schema:codeValue 2340,
        "0-23.40"^^xsd:string ;
    schema:description "Studies, designs and advises on telecommunication systems and equipment and plans and supervises their development, construction, installation, operation, maintenance and repair."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Telecommunications Engineer"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/02390> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/023> ;
    schema:codeValue 2390,
        "0-23.90"^^xsd:string ;
    schema:description "This group includes electrical and electronics engineers not elsewhere classified, for example those who perform tasks similar to those of Electrical engineer, general (0-23.05) or Electronics engineer, general (0-23.10) but specialise in the design, production, operation or maintenance of particular apparatus or products such as electronic calculating and data-processing equipment; radar, radio or television; signalling and automatic control systems; electric traction equipment; electric motors; domestic electrical appliances; or other electrical or electronic apparatus (excluding power generation, transmission and distribution and telecommunications equipment)."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Other Electrical and Electronics Engineers"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/02410> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/024> ;
    schema:codeValue 2410,
        "0-24.10"^^xsd:string ;
    schema:description "Carries out research on, designs and advises on mechanically functioning plant and equipment, and plans and supervises their development, manufacture, construction, installation, operation, maintenance and repair."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Mechanical Engineer, General"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/02420> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/024> ;
    schema:codeValue 2420,
        "0-24.20"^^xsd:string ;
    schema:description "Studies, designs and advises on machinery and tools for manufacturing, mining, construction, agricultural work, printing and other industrial purposes, and plans and supervises their development, manufacture, installation, operation, maintenance and repair."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Industrial Machinery and Tools Engineer"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/02430> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/024> ;
    schema:codeValue 2430,
        "0-24.30"^^xsd:string ;
    schema:description "Studies, designs and advises on steam, internal combustion and other non-electric motors and engines as used for propulsion of railway locomotives, road vehicles or aeroplanes, or for driving industrial and other machinery, and plans and supervises their development, manufacture, installation, maintenance and repair. Engineers specialising in electric motors are classified in 0-23.90."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Mechanical Engineer (Motors and Engines, except Marine)"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/02440> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/024> ;
    schema:codeValue 2440,
        "0-24.40"^^xsd:string ;
    schema:description "Studies, designs and advises on ships' propulsion systems, power plants, heating and ventilating systems, steering gear, pumps and other mechanical and electrical equipment, and plans and supervises their development, construction, installation, maintenance and repair. A marine engineer who is a member of a ship's crew is classified in unit group 0-43."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Marine Engineer"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/02450> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/024> ;
    schema:codeValue 2450,
        "0-24.50"^^xsd:string ;
    schema:description "Studies, designs and advises on the hulls and superstructures of ships and other vessels, and plans and supervises their development, construction, maintenance and repair."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Ship Construction Engineer"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/02460> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/024> ;
    schema:codeValue 2460,
        "0-24.60"^^xsd:string ;
    schema:description "Studies, designs and advises on airframes, undercarriages and other equipment for aircraft, and plans and supervises their development, construction, maintenance and repair."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Aeronautical Engineer"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/02470> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/024> ;
    schema:codeValue 2470,
        "0-24.70"^^xsd:string ;
    schema:description "Studies, designs and advises on road vehicle bodies, suspension systems, brakes and other components, and plans and supervises their development and manufacture."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Automotive Engineer"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/02480> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/024> ;
    schema:codeValue 2480,
        "0-24.80"^^xsd:string ;
    schema:description "Studies, designs and advises on heating, ventilation and refrigeration systems and equipment, and plans and supervises their development, manufacture, installation, maintenance and repair."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Heating, Ventilation and Refrigeration Engineer"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/02485> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/024> ;
    schema:codeValue 2485,
        "0-24.85"^^xsd:string ;
    schema:description "Studies, designs and advises on mechanical plant and equipment for the release, control and utilisation of nuclear energy, and plans and supervises their development, manufacture, installation, maintenance and repair."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Nuclear Power Engineer"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/02490> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/024> ;
    schema:codeValue 2490,
        "0-24.90"^^xsd:string ;
    schema:description "This group includes mechanical engineers not elsewhere classified, for example those who perform tasks similar to those of Mechanical engineer, general (0-24.10) but specialise in the design, production or maintenance of particular apparatus or products such as precision instruments; cameras and projectors; typewriters, desk calculators, cash registers and ticket machines; duplicating and copying machines; mechanically functioning medical equipment; or special space vehicles and mechanical equipment for space exploration and travel."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Other Mechanical Engineers"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/02510> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/025> ;
    schema:codeValue 2510,
        "0-25.10"^^xsd:string ;
    schema:description "Carries out research on chemical engineering problems and develops and advises on processes for producing on a commercial scale the chemical or physical transformation of substances, as in the manufacture of chemicals, petroleum derivatives, metals, food products and synthetic materials, designs appropriate manufacturing plant and plans and supervises its construction, operation, maintenance and repair."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Chemical Engineer, General"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/02520> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/025> ;
    schema:codeValue 2520,
        "0-25.20"^^xsd:string ;
    schema:description "Studies, develops and advises on processes for the refining of crude oil, designs appropriate plant and plans and supervises its construction, operation, maintenance and repair."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Chemical Engineer (Petroleum)"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/02590> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/025> ;
    schema:codeValue 2590,
        "0-25.90"^^xsd:string ;
    schema:description "This group includes chemical engineers not elsewhere classified, for example those who perform tasks similar to those of Chemical engineer, general (0-25.10) but specialise in the development and efficient utilisation of fuels; the design, construction, operation and maintenance of plant for the physical and chemical transformation of matter for the manufacture of a particular type of commodity such as antibiotics, plastics, explosives, rubber or pigments, or of plant for production and distribution of fuel gas for industrial, domestic and other purposes."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Other Chemical Engineers"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/02620> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/026> ;
    schema:codeValue 2620,
        "0-26.20"^^xsd:string ;
    schema:description "Studies, develops, advises on and controls the application of processes for the extraction of metals from their ores."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Extractive Metallurgist"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/02630> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/026> ;
    schema:codeValue 2630,
        "0-26.30"^^xsd:string ;
    schema:description "Studies properties of metals and alloys, develops new alloys and advises on and supervises technical aspects of metal and alloy manufacture and processing."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Physical Metallurgist"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/02690> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/026> ;
    schema:codeValue 2690,
        "0-26.90"^^xsd:string ;
    schema:description "This group includes metallurgists not elsewhere classified, for example those who specialise in metallurgical problems of radioactive materials."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Other Metallurgists"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/02710> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/027> ;
    schema:codeValue 2710,
        "0-27.10"^^xsd:string ;
    schema:description "Carries out research on mining engineering problems, advises on the extraction of metallic and solid nonmetallic minerals from the earth, supervises mineral prospecting and plans, organises and supervises mineral mining operations and preparation of minerals for distribution or processing."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Mining Engineer, General"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/02720> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/027> ;
    schema:codeValue 2720,
        "0-27.20"^^xsd:string ;
    schema:description "Studies and advises on coal-mining engineering problems and plans, organises and supervises coal-mining operations and preparation of coal for distribution."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Coal-Mining Engineer"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/02730> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/027> ;
    schema:codeValue 2730,
        "0-27.30"^^xsd:string ;
    schema:description "Studies and advises on metal-mining engineering problems and plans, organises and supervises metal-mining operations and preparation of metallic ores for distribution or processing. Engineers who specialise in the extraction of minerals from alluvial deposits by sluicing or dredging are classified in 0-27.90."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Metal-Mining Engineer"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/02740> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/027> ;
    schema:codeValue 2740,
        "0-27.40"^^xsd:string ;
    schema:description "Studies and advises on petroleum and natural gas extraction engineering problems, and plans, organises and supervises the extraction, storage, intial treatment and transportation of petroleum and natural gas."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Petroleum and Natural Gas Engineer"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/02790> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/027> ;
    schema:codeValue 2790,
        "0-27.90"^^xsd:string ;
    schema:description "This group includes mining engineers not elsewhere classified, for example those who perform tasks similar to those of Mining engineer, general (0-27.10) but specialise in mining or quarrying solid minerals (other than coal and metallic minerals) such as stone, marble, clay, salt, gravel or diamonds; extracting subsurface water or sulphur and other solid minerals by drilling boreholes; or extracting tin, gold, diamonds or other solid minerals from alluvial deposits by sluicing and dredging."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Other Mining Engineers"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/02810> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/028> ;
    schema:codeValue 2810,
        "0-28.10"^^xsd:string ;
    schema:description "Studies and advises on the organisation of production processes and commercial and administrative procedures, plans and supervises time and motion studies and makes recommendations to promote efficiency and supervises their implementation."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Industrial Efficiency Engineer, General"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/02820> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/028> ;
    schema:codeValue 2820,
        "0-28.20"^^xsd:string ;
    schema:description "Analyses industrial, commercial and other projects and administrative procedures, makes recommendations regarding organisation, methods of work and sequence of operations and supervises their implementation."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Methods Engineer"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/02830> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/028> ;
    schema:codeValue 2830,
        "0-28.30"^^xsd:string ;
    schema:description "Studies, develops and advises on work measurement procedures, plans and supervises time and motion studies, makes recommendations to promote efficiency and supervises their implementation."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Time and Motion Study Engineer"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/02890> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/028> ;
    schema:codeValue 2890,
        "0-28.90"^^xsd:string ;
    schema:description "This group includes industrial engineers not elsewhere classified, for example those who specialise in the prevention of industrial accidents and diseases by identifying potential hazards and developing and introducing safety procedures and devices, and those who specialise in the efficient layout of industrial plant or commercial establishments."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Other Industrial Engineers"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/02920> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/029> ;
    schema:codeValue 2920,
        "0-29.20"^^xsd:string ;
    schema:description "Carries out research and advises on, designs, develops and controls processes and plant for the manufacture of bricks, pottery and glassware."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Ceramics and Glass Technologist"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/02930> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/029> ;
    schema:codeValue 2930,
        "0-29.30"^^xsd:string ;
    schema:description "Studies and advises on the application of engineering technology to agricultural problems, designs agricultural machinery, structures and equipment and plans and supervises their manufacture, construction and installation. Engineers specialising in civil, mechanical or other particular types of engineering problems affecting the agricultural industry are classified elsewhere in minor group 0-2/0-3."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Agricultural Engineer"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/02940> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/029> ;
    schema:codeValue 2940,
        "0-29.40"^^xsd:string ;
    schema:description "Carries out research and advises on, designs, develops and controls processes and plant for the manufacture and processing of foods and beverages."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Food and Drink Technologist"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/02950> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/029> ;
    schema:codeValue 2950,
        "0-29.50"^^xsd:string ;
    schema:description "Studies, plans and advises on the routing and control of road traffic to promote safety and minimise congestion."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Traffic Planner"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/02990> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/029> ;
    schema:codeValue 2990,
        "0-29.90"^^xsd:string ;
    schema:description "This group includes engineers not elsewhere classified, for example those who study, design, develop, control and advise on processes and plant for the manufacture or processing of textiles, leather products, wood or paper."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Other Engineers"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/03010> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/030> ;
    schema:codeValue 3010,
        "0-30.10"^^xsd:string ;
    schema:description "Surveys earth's surface, natural topography and manmade structures, and underground areas to delineate features and determine exact locations and measurements for such purposes as mapmaking, construction work and mining."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Surveyor, General"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/03020> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/030> ;
    schema:codeValue 3020,
        "0-30.20"^^xsd:string ;
    schema:description "Surveys land surfaces to determine boundaries and exact locations, delineate topographic features and man-made structures and otherwise measure land areas for such purposes as mapmaking and construction work."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Land Surveyor"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/03030> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/030> ;
    schema:codeValue 3030,
        "0-30.30"^^xsd:string ;
    schema:description "Surveys mines and delineates surface and underground features to control direction and extent of mining."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Mine Surveyor"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/03040> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/030> ;
    schema:codeValue 3040,
        "0-30.40"^^xsd:string ;
    schema:description "Surveys sea, river and lake beds to delineate underwater topographic features for such purposes as chart making, determining navigable channels and planning construction and repair of harbours, piers, breakwaters and other marine structures."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Hydrographic Surveyor"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/03050> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/030> ;
    schema:codeValue 3050,
        "0-30.50"^^xsd:string ;
    schema:description "Analyses photographs and survey data to prepare and revise topographic maps and charts."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Photogrammetrist"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/03090> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/030> ;
    schema:codeValue 3090,
        "0-30.90"^^xsd:string ;
    schema:description "This group includes surveyors not elsewhere classified, for example those who specialise in planning and constructing aerial photographic surveys."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
