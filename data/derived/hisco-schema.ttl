    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/310> ;
    schema:codeValue 31020,
        "3-10.20"^^xsd:string ;
    schema:description "Receives taxes on behalf of local, regional or central administration. May collect duty and impose penalties for contravention of tax regulations. May do so in person or via correspondence."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Tax Collector"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/31030> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
