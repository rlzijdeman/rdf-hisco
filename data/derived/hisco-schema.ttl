    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Cost Computing Clerk"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/33930> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/339> ;
    schema:codeValue 33930,
        "3-39.30"^^xsd:string ;
    schema:description "Calculates wages due from records of hours worked or work performed by individual employees. Workers whose duties consist mainly of maintaining records of time worked, or periods workers have been on duty, are classified in 3-39.90."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Wages Clerk"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/33940> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/339> ;
    schema:codeValue 33940,
        "3-39.40"^^xsd:string ;
    schema:description "Carries out specialised clerical tasks relating to financial transactions of a bank, investment house or other financial organisation."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Finance Clerk"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/33990> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/339> ;
