        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/075> ;
    schema:codeValue 7520,
        "0-75.20"^^xsd:string ;
    schema:description "Examines eyes and prescribes spectacles or treatment not involving the use of medicines, surgery or drugs, to conserve or improve vision."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Optometrist"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/07530> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/075> ;
    schema:codeValue 7530,
        "0-75.30"^^xsd:string ;
    schema:description "Assists customer in choice of frames, selects the lenses prescribed, fits lenses in frames and fits frames to customer, or fits contact lenses according to prescription."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Dispensing Optician"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/07620> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/076> ;
    schema:codeValue 7620,
        "0-76.20"^^xsd:string ;
    schema:description "Treats sprains, healing fractures, paralysis, circulatory and nervous disorders by physical means, usually as prescribed by a physician."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Physiotherapist"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/07630> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/076> ;
    schema:codeValue 7630,
        "0-76.30"^^xsd:string ;
    schema:description "Participates in planned medically oriented vocational, educational or recreational activities designed to rehabilitate physically or mentally disabled persons."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Occupational Therapist"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/07640> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/076> ;
    schema:codeValue 7640,
        "0-76.40"^^xsd:string ;
    schema:description "Massages clients or patients to improve circulation, soothe or stimulate nerves, facilitate elimination of waste matter, stretch contracted tendons and produce other therapeutic effects."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Masseur"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/07710> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/077> ;
    schema:codeValue 7710,
        "0-77.10"^^xsd:string ;
    schema:description "Operates X-ray equipment to make radiographs for medical diagnostic purposes or to give therapeutic treatment."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Medical X-Ray Technician"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/07920> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/079> ;
    schema:codeValue 7920,
        "0-79.20"^^xsd:string ;
    schema:description "Diagnoses and treats, mainly by manipulative methods, disorders of bones, muscles, blood vessels and other tissues of the human body."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Osteopath"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/07930> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/079> ;
    schema:codeValue 7930,
        "0-79.30"^^xsd:string ;
    schema:description "Relieves illness believed due to pressure upon nervous system at the spine by adjusting joints of the spine."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Chiropractor"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/07940> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/079> ;
    schema:codeValue 7940,
        "0-79.40"^^xsd:string ;
