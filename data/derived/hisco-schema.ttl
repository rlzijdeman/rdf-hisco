    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/342> ;
    schema:codeValue 34230,
        "3-42.30"^^xsd:string ;
    schema:description "Operates machines in which cards punched with holes representing statistical or other data are sorted into specific groups, or machines which process data from cards into tabulated and recorded form. Card- and tape-punching machine operator is classified in 3-22.20."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Punched-Card Machine Operator"@en-gb .

