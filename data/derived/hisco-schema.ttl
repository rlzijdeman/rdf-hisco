    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Sales Supervisor (Retail Trade)"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/22390> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
