    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/226> ;
    schema:codeValue 22690,
        "2-26.90"^^xsd:string ;
    schema:description "This group includes other supervisors and general foremen not elsewhere classified. Included are those performing tasks similar to those of Production supervisor or general foreman, general (2-26.10) in a production unit concerned with an activity such as printing; processing non-metallic minerals; processing skins, pelts and leathers; fabricating wood, stone, clay and glass products; fabricating products made from assorted materials."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Other Production Supervisors and General Foremen"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/30000> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/300> ;
    schema:codeValue 30000,
        "3-00.00"^^xsd:string ;
