    schema:codeValue 34290,
        "3-42.90"^^xsd:string ;
    schema:description "This group includes automatic data processing machine operators not elsewhere classified, for example those who operate card-to-tape or tape-to-card converting machines; operate optical scanning equipment for transferring mechanically information represented by specially marked characters to punched cards, tape or other documents; or operate other specialised equipment for use in connection with computers such as high speed printing equipment."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Other Automatic Data-Processing Machine Operators"@en-gb .

