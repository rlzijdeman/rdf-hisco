    schema:description "Makes forecasts of future events for particular clients or the general public basing predictions either on the positions of stars and planets at specified times or on characteristics of clients' palms, samples of playing cards drawn at random, or other factors. Performers entertaining audiences by mock interpretations of signs in palms, playing cards, crystal balls or other media and by giving demonstrations of professed powers of mental telepathy are classified in 1-79.90."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Astrologer and Fortune Teller"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/19990> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/199> ;
    schema:codeValue 19990,
        "1-99.90"^^xsd:string ;
    schema:description "This group includes other professional, technical and related workers not elsewhere classified, for example those who act as agents for writers in the obtaining and negotiation of contracts for the publication of their works, or arrange contracts for performing artists and take care of their business interests."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Other Professional, Technical and Related Workers Not Elsewhere Classified"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/20110> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/201> ;
    schema:codeValue 20110,
        "2-01.10"^^xsd:string ;
    schema:description "Presides over, or takes part in, the activities of a national, state, provincial or local government legislative body or administrative council as an elected or appointed member."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Legislative Official"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/20210> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/202> ;
    schema:codeValue 20210,
        "2-02.10"^^xsd:string ;
    schema:description "Plans, organises, directs and controls, subject to a broad mandate from political head or governing body, the activities of a national, state, provincial or local government department (or subdepartment), government administrative agency or intergovernmental organisation (or one of its departments); advises political head or governing body on important policy questions; makes decisions within his or her broad discretionary power; performs other high-level functions in connection with government administration."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Government Administrator"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/21000> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/210> ;
    schema:codeValue 21000,
        "2-10.00"^^xsd:string ;
    schema:description "May perform any (but not all) of the occupational activities described in minor group 2-1."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Manager, Specialisation Unknown"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/21110> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/211> ;
    schema:codeValue 21110,
        "2-11.10"^^xsd:string ;
    schema:description "Plans, organises, directs and controls, on proprietors' or on own behalf, an industrial, commercial or other undertaking, establishment or organisation, and coordinates the work of departmental managers or other immediate subordinates. Where the simple, undefined term >Manufacturer= occurs it can be coded to either 2-11.10 or 9-99.99. Where the title indicates a manufacturer of something (e.g. >Fabricant de papier=) it can be coded to either 2-11.10 or the relevant production code in Major Groups 7, 8 or 9 (i.e. in the case of >Fabricant de papier=, 7-34.00). Examples of the latter product-defining titles are not given below but are listed in the alphabetical language-based coding index."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "General Manager"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/21200> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/212> ;
    schema:codeValue 21200,
        "2-12.00"^^xsd:string ;
    schema:description "May perform any (but not all) of the occupational activities described in unit group 2-12."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Production Manager, Specialization Unknown"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/21220> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/212> ;
    schema:codeValue 21220,
        "2-12.20"^^xsd:string ;
    schema:description "Plans, organises and controls the production activities of an undertaking or establishment, ensuring efficient use of equipment, materials and personnel, and participates in formulating the production policy of the undertaking."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Production Manager (except Farm)"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/21230> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/212> ;
    schema:codeValue 21230,
        "2-12.30"^^xsd:string ;
    schema:description "Plans, organises and controls the operation of a farm on behalf of private, collective or public owner."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Farm Manager"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/21240> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/212> ;
    schema:codeValue 21240,
        "2-12.40"^^xsd:string ;
    schema:description "Contracts on predetermined terms to provide labour and materials and to be responsible for the completion of a job or project in accordance with established specifications or plans."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Contractor"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/21300> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/213> ;
    schema:codeValue 21300,
        "2-13.00"^^xsd:string ;
    schema:description "May perform any (but not all) of the occupational activities described in unit group 2-13."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Sales Manager, Specialisation Unknown"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/21320> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/213> ;
    schema:codeValue 21320,
        "2-13.20"^^xsd:string ;
    schema:description "Plans, organises and controls sales activities of an industrial undertaking or other organisation, except a wholesale or retail business, and participates in formulating sales policy."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Sales Manager (except Wholesale and Retail Trade)"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/21330> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/213> ;
    schema:codeValue 21330,
        "2-13.30"^^xsd:string ;
    schema:description "Plans and organises a business or a branch of a business in wholesale trade and directs workers engaged in selling goods to retailers and to industrial, commercial or other large consumers."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Sales Manager (Wholesale Trade)"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/21340> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/213> ;
    schema:codeValue 21340,
        "2-13.40"^^xsd:string ;
    schema:description "Plans and organises a business in retail trade and directs workers engaged in selling goods for personal or household consumption or utilisation."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Sales Manager (Retail Trade)"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/21420> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/214> ;
    schema:codeValue 21420,
        "2-14.20"^^xsd:string ;
    schema:description "Plans and organises a hotel and restaurant or motel on behalf of the proprietors to provide accommodation and meals for guests and directs and controls staff to ensure efficient and profitable operation."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Hotel and Restaurant Manager"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/21430> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/214> ;
    schema:codeValue 21430,
        "2-14.30"^^xsd:string ;
    schema:description "Plans and organises a restaurant on behalf of the proprietors to provide food and beverages for guests, and directs and controls staff to ensure efficient and profitable operation."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Restaurant Manager"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/21440> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/214> ;
    schema:codeValue 21440,
        "2-14.40"^^xsd:string ;
    schema:description "Supervises and co-ordinates activities of crew members aboard ship concerned with shipboard business matters and social activities of passengers."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Ship's Purser"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/21490> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/214> ;
    schema:codeValue 21490,
        "2-14.90"^^xsd:string ;
    schema:description "This group includes catering, lodging and leisure managers not elsewhere classified, for example those who manage temporary or permanent lodging facilities, such as boarding or guest houses and caravan parks; cafeterias, bars, cafés and canteens; refreshment stands at sporting events, and public gatherings. This group also includes those who manage leisure facilities, such as sports halls, swimming pools, playing fields, recreation rooms and amusement parks."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Other Managers (Catering, Lodging and Leisure Services)"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/21920> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/219> ;
    schema:codeValue 21920,
        "2-19.20"^^xsd:string ;
    schema:description "Plans, organises and controls research and development work, in an industrial enterprise or other establishment, relating to such matters as development of new or improved technical processes, new or improved products and utilisation of different materials, and participates in formulating research policy."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Research and Development Manager"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/21940> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/219> ;
    schema:codeValue 21940,
        "2-19.40"^^xsd:string ;
    schema:description "Plans, organises and controls the internal administration of an industrial, commercial or other organisation and participates in formulating the administrative policy of the organisation. Workers sometimes described as \"office managers\", who are occupied mainly in directly supervising workers in clerical occupations, are classified in unit group 2-21."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Administration Manager"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/21950> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/219> ;
    schema:codeValue 21950,
        "2-19.50"^^xsd:string ;
    schema:description "Plans, organises and controls, within powers delegated to him, the financial operations of an industrial, commercial or other organisation and participates in formulating the financial policy of the organisation."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Budgeting and Accounting Manager"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/21960> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/219> ;
    schema:codeValue 21960,
        "2-19.60"^^xsd:string ;
    schema:description "Plans, organises and controls operational activities in road, rail, air or water transport and participates in formulating policies to ensure the efficient handling of freight and passenger traffic and the best use of transport equipment. Railway station managers are classified in 2-22.10."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Transport Operations Managers"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/21970> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/219> ;
    schema:codeValue 21970,
        "2-19.70"^^xsd:string ;
    schema:description "Plans, organises and controls operational activities of a postal or telecommunications service and participates in formulating policy concerning operation and development of the service. Postmasters are classified in 2-22.20."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Operations Manager (Postal or Telecommunications Services)"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/21980> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/219> ;
    schema:codeValue 21980,
        "2-19.80"^^xsd:string ;
    schema:description "Plans, organises and controls industrial relations and personnel activities of an industrial or commercial undertaking or other organisation and participates in formulating the recruitment, training, wages, safety, welfare and other personnel policies of the undertaking."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Industrial Relations and Personnel Manager"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/21990> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/219> ;
    schema:codeValue 21990,
        "2-19.90"^^xsd:string ;
    schema:description "Workers in this group plan, organise, direct and control a department within an undertaking, establishment or organisation, such as departments concerned with the following: buying business and other services or supplies and materials for processing and fabrication; warehouse, bond store or cold store services; pipeline services; advertising, public relations and public information services; investment and loans services; or perform other managerial activities not elsewhere classified."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Other Managers"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/22000> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/220> ;
    schema:codeValue 22000,
        "2-20.00"^^xsd:string ;
    schema:description "May perform any (but not all) of the occupational activities described in minor group 2-2."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Supervisor, Foremen or Inspector, Specialisation Unknown"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/22110> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/221> ;
    schema:codeValue 22110,
        "2-21.10"^^xsd:string ;
    schema:description "Supervises and co-ordinates the daily activities of workers engaged in clerical and related duties in the general office of a public or private establishment, or of those engaged in such work in more than one section of an establishment."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Clerical Supervisor, General"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/22190> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/221> ;
    schema:codeValue 22190,
        "2-21.90"^^xsd:string ;
    schema:description "This group includes clerical supervisors not elsewhere classified, for example those who supervise workers engaged in various clerical and related occupations in one particular section of an establishment."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Other Clerical Supervisors"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/22210> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/222> ;
    schema:codeValue 22210,
        "2-22.10"^^xsd:string ;
    schema:description "Organises, controls and co-ordinates passenger and related railway services at a railway station and supervises the operation of trains within the station limits."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Railway Station Master"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/22220> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/222> ;
    schema:codeValue 22220,
        "2-22.20"^^xsd:string ;
    schema:description "Organises, controls and co-ordinates postal and related services in an urban locality or other limited geographical area."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Postmaster"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/22230> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/222> ;
    schema:codeValue 22230,
        "2-22.30"^^xsd:string ;
    schema:description "Supervises and co-ordinates one or more of the service activities of the traffic department of a railway undertaking. Railway station master is classified in 2-22.10 and Railway goods agent in 2-22.45."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Railway Service Supervisor"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/22235> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/222> ;
    schema:codeValue 22235,
        "2-22.35"^^xsd:string ;
    schema:description "Directs the movement of trains within a division or zone of a railway system."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Train Dispatcher"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/22240> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/222> ;
    schema:codeValue 22240,
        "2-22.40"^^xsd:string ;
    schema:description "Makes field inspections of railway and underground transport services."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Railway Transport Service Inspector"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/22245> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/222> ;
    schema:codeValue 22245,
        "2-22.45"^^xsd:string ;
    schema:description "Directs and controls freight service at a railway yard."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Railway Goods Agent"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/22250> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/222> ;
    schema:codeValue 22250,
        "2-22.50"^^xsd:string ;
    schema:description "Supervises and co-ordinates one or more of the service activities of the traffic department of a road transport undertaking."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Road Transport Service Supervisor"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/22255> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/222> ;
    schema:codeValue 22255,
        "2-22.55"^^xsd:string ;
    schema:description "Makes field inspections of road passenger transport services."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Road Passenger Transport Service Inspector"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/22260> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/222> ;
    schema:codeValue 22260,
        "2-22.60"^^xsd:string ;
    schema:description "Supervises and co-ordinates one or more service activities of an air transport undertaking."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Air Transport Service Supervisor"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/22265> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/222> ;
    schema:codeValue 22265,
        "2-22.65"^^xsd:string ;
    schema:description "Clears aircraft for landings and take-offs at airport and controls aircraft in flight in the vicinity of airport or in a designated sector of airspace."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Air Traffic Controller"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/22270> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/222> ;
    schema:codeValue 22270,
        "2-22.70"^^xsd:string ;
    schema:description "Co-ordinates flight planning and assists in monitoring of en-route operations."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Flight Operations Officer"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/22275> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/222> ;
    schema:codeValue 22275,
        "2-22.75"^^xsd:string ;
    schema:description "Controls and supervises telecommunications operational services, such as radio, telephone and telegraph. Foremen-supervisors concerned with installation and maintenance of telecommunications equipment are classified in unit group 8-56 and Telecommunications engineers are classified in 0-23.40."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Telecommunications Service Supervisor"@en-gb .

