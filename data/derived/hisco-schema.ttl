    schema:codeValue 22630,
        "2-26.30"^^xsd:string ;
    schema:description "Supervises production activities of a distinct unit within a metal-processing establishment and controls and co-ordinates the activities of workers in this unit engaged in various occupations."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
