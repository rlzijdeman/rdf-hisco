    schema:codeValue 34220,
        "3-42.20"^^xsd:string ;
    schema:description "Sets and controls electronic computer to process business, scientific, engineering or other data according to operating instructions. Computer programmer is classified in 0-84.20."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Electronic Computer Operator"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/34230> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
