    schema:codeValue 22610,
        "2-26.10"^^xsd:string ;
    schema:description "Supervises production activities in a distinct unit within an establishment, and controls and co-ordinates activities of workers in this unit engaged in various processing and fabricating occupations."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Production Supervisor or Foreman, General"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/22620> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
