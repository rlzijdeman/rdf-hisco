    schema:codeValue 22490,
        "2-24.90"^^xsd:string ;
    schema:description "This group includes housekeeping supervisors not elsewhere classified, for example those who perform supervisory tasks in establishments providing only shelter, such as tourist camps and lodging houses; act as butler in private households."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Other Housekeeping and Related Service Supervisors"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/22520> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
