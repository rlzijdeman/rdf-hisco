    schema:codeValue 7990,
        "0-79.90"^^xsd:string ;
    schema:description "This group includes medical, dental, veterinary and related workers not elsewhere classified, for example those treating sickness through the application of various herbs and medicinal plants; those treating patients with a system of physical culture and drugless treatment of disease by methods aimed to stimulate or assist nature; those treating body ailments and nervous disorders through mental influence and suggestion; those who treat physical ailments by means of therapeutic baths and other treatments; those carrying out minor surgical procedures connected, for example, with ailments of the human foot; those diagnosing and treating minor ailments of the human foot such as corns, callouses, deformed toenails, flat feet and other disorders and advising patients on further treatment, proper foot care and suitable footwear."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Other Medical, Dental, Veterinary and Related Workers"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/08110> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/081> ;
    schema:codeValue 8110,
        "0-81.10"^^xsd:string ;
    schema:description "Conducts research to develop new and improved statistical methods, advises on practical applications of statistical methods, plans and conducts statistical surveys, and organises, analyses and interprets statistical data."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Statistician, General"@en-gb .

