    schema:codeValue 54010,
        "5-40.10"^^xsd:string ;
    schema:description "Cleans rooms, prepares food and serves meals, washes dishes and performs additional domestic duties in private households (5-40.20). May also attend to employer=s personal needs (5-40.30), take care of children (5-40.35), or provide companionship for employer (5-40.40)."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
