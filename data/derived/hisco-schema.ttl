    schema:description "This group includes bookkeepers, cashiers and other related workers not elsewhere classified, for example those collecting rents or hire purchase payments; keeping records of times of arrival and departure of workers; changing currency units of large denominations into smaller units."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Other Bookkeepers, Cashiers and Related Workers"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/34120> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/341> ;
    schema:codeValue 34120,
