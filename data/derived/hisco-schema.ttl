    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Occupational Health Nurse"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/07190> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/071> ;
    schema:codeValue 7190,
        "0-71.90"^^xsd:string ;
    schema:description "This group includes professional nurses not elsewhere classified, for example those specialising in provision of consultant services to industrial and other organisations; or in giving private general nursing care to patients in their homes."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Other Professional Nurses"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/07210> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/072> ;
    schema:codeValue 7210,
        "0-72.10"^^xsd:string ;
    schema:description "Provides simple nursing services to patients, generally under the supervision of a physician or professional nurse. Nursing aid is classified in 5-99.40."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Auxiliary Nurse"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/07310> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/073> ;
    schema:codeValue 7310,
        "0-73.10"^^xsd:string ;
    schema:description "Gives professional care and advice to women to aid them during pregnancy, childbirth and the postnatal period. A professional nurse specialising in obstetrics is classified as Specialised nurse (0-71.20)."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Professional Midwife"@en-gb .

