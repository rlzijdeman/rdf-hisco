    schema:description "This group includes engineering technicians not elsewhere classified, for example those who specialise in performing technical tasks contributory to technological development of processes and plant, or technical supervision of processing operations, relating to the manufacture of bricks, pottery and glassware; of food and beverages; textiles; paper; leather or wood products; those assisting safety engineers, agricultural engineers, or traffic planners; and those performing other technical tasks in engineering not performed by workers classified elsewhere."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Other Engineering Technicians"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/04120> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/041> ;
    schema:codeValue 4120,
        "0-41.20"^^xsd:string ;
    schema:description "Flies aircraft transporting passengers, mail or freight."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Air Transport Pilot"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/04125> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/041> ;
    schema:codeValue 4125,
        "0-41.25"^^xsd:string ;
    schema:description "Flies aircraft for transport of passengers, mail, or freight or for other purposes."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Aircraft Pilot (Transport or Other Purposes)"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/04130> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/041> ;
    schema:codeValue 4130,
        "0-41.30"^^xsd:string ;
    schema:description "Pilots aircraft for purposes other than passenger, mail or freight transportation, such as for testing or delivering aircraft, spraying insecticides and fungicides for pest control, aerial surveys, aerial photography, and exhibitions of flying skill."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Aircraft Pilot (except Transport)"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/04140> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/041> ;
    schema:codeValue 4140,
        "0-41.40"^^xsd:string ;
    schema:description "Directs course of aircraft in flight according to predetermined flight plan or as directed by pilot-in-command."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Flight Navigator"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/04150> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/041> ;
    schema:codeValue 4150,
        "0-41.50"^^xsd:string ;
    schema:description "Makes pre-flight, in-flight and post-flight inspections, carries out adjustments and minor repairs to ensure safe and efficient operation of aircraft and monitors control panel during flight."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Flight Engineer"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/04160> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/041> ;
    schema:codeValue 4160,
        "0-41.60"^^xsd:string ;
    schema:description "Teaches trainee pilots to operate the controls of an aircraft and instructs them in aircraft piloting techniques and procedures."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Flying Instructor"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/04200> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/042> ;
    schema:codeValue 4200,
        "0-42.00"^^xsd:string ;
    schema:description "May perform any (but not all) of the occupational activities described in unit group 0-42."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Ships' Deck Officer or Pilot, Specialisation Unknown"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/04215> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/042> ;
    schema:codeValue 4215,
        "0-42.15"^^xsd:string ;
    schema:description "Takes complete charge of seagoing ship and directs, co-ordinates and supervises shipboard activities."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Ship's Master (Sea)"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/04217> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/042> ;
    schema:codeValue 4217,
        "0-42.17"^^xsd:string ;
    schema:description "Takes complete charge of seagoing ship or vessel confined to inland waterways and directs, co-ordinates and supervises shipboard activities."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Ship's Master (Sea or Inland Waterways)"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/04220> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/042> ;
    schema:codeValue 4220,
        "0-42.20"^^xsd:string ;
    schema:description "Takes complete charge of vessel confined to inland waterways and directs, co-ordinates and supervises activities on board. Boatman is classified in 9.81.90."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Ship's Master (Inland Waterways)"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/04230> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/042> ;
    schema:codeValue 4230,
        "0-42.30"^^xsd:string ;
    schema:description "Plans, supervises and co-ordinates deck and bridge-watch activities on seagoing or inland waterways vessel."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Ship's Navigating Officer"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/04240> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/042> ;
    schema:codeValue 4240,
        "0-42.40"^^xsd:string ;
    schema:description "Navigates vessels into and out of ports, in rivers, channels, straits and other waters where special knowledge and skill are required."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Ship Pilot"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/04250> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/042> ;
    schema:codeValue 4250,
        "0-42.50"^^xsd:string ;
    schema:description "Directs or arranges on-shore services such as supply of ships' stores and equipment, ship inspections and overhauls, crew replacements and navigational information for shipping company vessels arriving in port. Marine superintendent (technical) is classified in 0-43.30."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Marine Superintendent (Deck)"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/04290> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/042> ;
    schema:codeValue 4290,
        "0-42.90"^^xsd:string ;
    schema:description "This group includes ships' deck officers and pilots not elsewhere classified, for example those in charge of seagoing yachts and hovercraft."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Other Ships' Deck Officers and Pilots"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/04315> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/043> ;
    schema:codeValue 4315,
        "0-43.15"^^xsd:string ;
    schema:description "Plans, co-ordinates and directs engine-room department aboard ship and supervises subordinate marine engineer officers and engine-room ratings."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Ship's Chief Engineer"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/04320> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/043> ;
    schema:codeValue 4320,
        "0-43.20"^^xsd:string ;
    schema:description "Controls, and participates in, the operation, maintenance and repair of engines, electrical motors, boilers, pumps, compressors, heat exchangers, and other machinery and equipment on board ship under the general direction of chief engineer."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Marine Engineer Officer"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/04330> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/043> ;
    schema:codeValue 4330,
        "0-43.30"^^xsd:string ;
    schema:description "Directs from shore station the maintenance programmes for machinery and equipment on board company's ships, directs or authorises repairs in port and directs replacement programme for shipboard machinery."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Marine Superintendent (Technical)"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/05110> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/051> ;
    schema:codeValue 5110,
        "0-51.10"^^xsd:string ;
    schema:description "Conducts research into all forms of life to increase scientific knowledge and develops practical applications in fields such as medicine and agriculture."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Biologist, General"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/05120> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/051> ;
    schema:codeValue 5120,
        "0-51.20"^^xsd:string ;
    schema:description "Conducts research into all forms of plant life to increase scientific knowledge and develop practical applications in fields such as agriculture and forestry."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Botanist"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/05130> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/051> ;
    schema:codeValue 5130,
        "0-51.30"^^xsd:string ;
    schema:description "Conducts research into all forms of animal life to increase scientific knowledge and develop practical applications in fields such as agriculture and medicine."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Zoologist"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/05190> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/051> ;
    schema:codeValue 5190,
        "0-51.90"^^xsd:string ;
    schema:description "This group includes biologists, zoologists and related scientists not elsewhere classified, for example those who specialise in marine and freshwater life."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Other Biologists, Zoologists and Related Scientists"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/05220> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/052> ;
    schema:codeValue 5220,
        "0-52.20"^^xsd:string ;
    schema:description "Conducts research into the form, structure and other anatomical characteristics of humans and animals to increase scientific knowledge and develop practical applications in medical and related fields."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Anatomist"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/05230> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/052> ;
    schema:codeValue 5230,
        "0-52.30"^^xsd:string ;
    schema:description "Conducts research into chemical composition and processes of living organisms to increase scientific knowledge and develop industrial, medical and other practical applications."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Biochemist"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/05240> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/052> ;
    schema:codeValue 5240,
        "0-52.40"^^xsd:string ;
    schema:description "Conducts research into biological functions and activities of human organism under normal and abnormal conditions to increase scientific knowledge and develop practical applications in medical and related fields."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Physiologist"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/05250> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/052> ;
    schema:codeValue 5250,
        "0-52.50"^^xsd:string ;
    schema:description "Conducts research into nature and characteristics of bacteria and other micro-organisms to increase scientific knowledge and develop industrial, medical and other practical applications."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Bacteriologist"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/05260> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/052> ;
    schema:codeValue 5260,
        "0-52.60"^^xsd:string ;
    schema:description "Conducts research into nature, causes and development of human diseases and disorders."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Medical Pathologist"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/05265> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/052> ;
    schema:codeValue 5265,
        "0-52.65"^^xsd:string ;
    schema:description "Conducts research into nature, causes and development of animal diseases and disorders."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Veterinary Pathologist"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/05270> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/052> ;
    schema:codeValue 5270,
        "0-52.70"^^xsd:string ;
    schema:description "Conducts research into effects of drugs and other substances on organs, tissues and life processes of humans and animals and develops new and improved medicinal drugs."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Pharmacologist"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/05280> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/052> ;
    schema:codeValue 5280,
        "0-52.80"^^xsd:string ;
    schema:description "Conducts research into animal genetics, advanced animal husbandry methods and related matters and applies scientific knowledge to develop improved strains, improved methods of raising animals and higher yields of animal products."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Animal Scientist"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/05290> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/052> ;
    schema:codeValue 5290,
        "0-52.90"^^xsd:string ;
    schema:description "This group includes bacteriologists, pharmacologists and related scientists not elsewhere classified, for example those conducting research in the field of biophysics, relating to such problems as dynamics of seeing and hearing, transmission of electrical impulses along nerves and muscles, effects of light and other radiation on body cells, and developing practical applications for medical or other purposes."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Other Bacteriologists, Pharmacologists and Related Scientists"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/05320> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/053> ;
    schema:codeValue 5320,
        "0-53.20"^^xsd:string ;
    schema:description "Conducts research into field crops and grasses and develops new and improved production methods."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Agronomist"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/05330> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/053> ;
    schema:codeValue 5330,
        "0-53.30"^^xsd:string ;
    schema:description "Conducts research into horticultural crops and develops new and improved production methods."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Horticulturist"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/05340> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/053> ;
    schema:codeValue 5340,
        "0-53.40"^^xsd:string ;
    schema:description "Conducts research into, and develops methods of, tree propagation and culture and plans and directs afforestation, care and exploitation of forest stands."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Silviculturist"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/05350> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/053> ;
    schema:codeValue 5350,
        "0-53.50"^^xsd:string ;
    schema:description "Conducts research into characteristics, use capabilities and productivity of soils and applies findings to development of improved agricultural, horticultural and forestry practices."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Soil Scientist"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/05360> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/053> ;
    schema:codeValue 5360,
        "0-53.60"^^xsd:string ;
    schema:description "Advises farmers on farming methods and problems."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Farming Adviser"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/05390> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/053> ;
    schema:codeValue 5390,
        "0-53.90"^^xsd:string ;
    schema:description "This group includes agronomists and related scientists not elsewhere classified, for example those who investigate conditions and problems, make recommendations and develop improved methods relating to conservation of wild life reserves or economic exploitation of grazing lands."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Other Agronomists and Related Scientists"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/05400> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/054> ;
    schema:codeValue 5400,
        "0-54.00"^^xsd:string ;
    schema:description "May perform any (but not all) of the occupational activities described in unit group 0-54."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Life Science Technician, Specialisation Unknown"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/05420> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/054> ;
    schema:codeValue 5420,
        "0-54.20"^^xsd:string ;
    schema:description "Performs technical tasks, normally under direction and supervision of biological scientist, contributory to biological experiments, tests and analyses to increase scientific knowledge and develop industrial, public health, agricultural and other practical applications."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Biological Technician"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/05430> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/054> ;
    schema:codeValue 5430,
        "0-54.30"^^xsd:string ;
    schema:description "Performs technical tasks, normally under direction and supervision of medical scientist, contributory to experiments, tests and analyses for the diagnosis, treatment and prevention of sickness and disease."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Medical Science Technician"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/05490> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/054> ;
    schema:codeValue 5490,
        "0-54.90"^^xsd:string ;
    schema:description "This group includes life sciences technicians not elsewhere classified, for example those who specialise in performing technical tasks in connection with the collection, treatment, storage and distribution of semen for artificial breeding of farm animals; performing technical tasks to assist agronomists, horticulturists and silviculturists; or analysing samples of seeds for quality, purity and germination rating."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Other Life Sciences Technicians"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/06100> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/061> ;
    schema:codeValue 6100,
        "0-61.00"^^xsd:string ;
    schema:description "May perform any (but not all) of the occupational activities described in unit group 0-61."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Medical Doctor, Specialisation Unknown"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/06105> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/061> ;
    schema:codeValue 6105,
        "0-61.05"^^xsd:string ;
    schema:description "Conducts medical examinations, makes diagnoses, prescribes medicines, and gives other forms of treatment for various kinds of diseases, disorders and injuries of the human body; applies preventive medicine techniques to prevent diseases and promote good health."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "General Physician"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/06110> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/061> ;
    schema:codeValue 6110,
        "0-61.10"^^xsd:string ;
    schema:description "Performs various kinds of surgical operations in the treatment of injuries, diseases and disorders of the human body."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "General Surgeon"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/06120> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/061> ;
    schema:codeValue 6120,
        "0-61.20"^^xsd:string ;
    schema:description "Specialises in giving medical treatment and advice for particular types of diseases, disorders and injuries of the human body."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Specialised Physician"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/06130> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/061> ;
    schema:codeValue 6130,
        "0-61.30"^^xsd:string ;
    schema:description "Specialises in giving surgical treatment and advice for particular types of diseases and disorders of the human body."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Specialised Surgeon"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/06140> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/061> ;
    schema:codeValue 6140,
        "0-61.40"^^xsd:string ;
    schema:description "Exercises controls and supervision to implement or enforce public health laws and regulations for safeguarding and promoting the health of a community."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Public Health Physician"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/06190> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/061> ;
    schema:codeValue 6190,
        "0-61.90"^^xsd:string ;
    schema:description "This group includes medical doctors not elsewhere classified, for example those mainly employed in conducting medical examinations in schools, workplaces or elsewhere; those mainly employed in giving medical advice, for instance in connection with life or other insurance plans, social security funds, medical aspects of occupational risks, or otherwise."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Other Medical Doctors"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/06210> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/062> ;
    schema:codeValue 6210,
        "0-62.10"^^xsd:string ;
    schema:description "Performs to a limited extent the tasks of General physician (0-61.05) within a public health service or institution, more particularly as regards common diseases of the region, either independently or under the general direction of a fully qualified physician. The workers in this group have not had the full training of General physician (0-61.05)."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Medical Assistant"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/06310> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/063> ;
    schema:codeValue 6310,
        "0-63.10"^^xsd:string ;
    schema:description "Performs diagnostic, preventive and curative services for dental or oral diseases and disorders."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Dentist, General"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/06320> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/063> ;
    schema:codeValue 6320,
        "0-63.20"^^xsd:string ;
    schema:description "Specialises in giving surgical, medical and other forms of treatment for particular types of dental and oral diseases and disorders."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Specialised Dentist"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/06330> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/063> ;
    schema:codeValue 6330,
        "0-63.30"^^xsd:string ;
    schema:description "Plans and directs public action to improve oral health and to control and improve standards of dental care and treatment of oral disorders."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Public Health Dentist"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/06420> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/064> ;
    schema:codeValue 6420,
        "0-64.20"^^xsd:string ;
    schema:description "Carries out, but only to a limited extent, diagnostic, preventive and curative tasks in dentistry to assist dentists, or independently. The workers in this group have not had the full training of Dentists (0-63), and may be designated Practical dentist, Unregistered dentist or Dental auxiliary."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Dental Assistant"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/06430> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/064> ;
    schema:codeValue 6430,
        "0-64.30"^^xsd:string ;
    schema:description "Performs limited diagnostic, preventive and curative duties in dentistry for pre-school and schoolchildren under the direction and control of a dentist."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "School Dental Assistant"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/06440> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/064> ;
    schema:codeValue 6440,
        "0-64.40"^^xsd:string ;
    schema:description "Carries out dental prophylactic treatments and instructs groups and individuals in care of teeth and mouth."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Dental Hygienist"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/06510> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/065> ;
    schema:codeValue 6510,
        "0-65.10"^^xsd:string ;
    schema:description "Diagnoses and gives or prescribes medical and surgical treatment of diseases, injuries or other medical conditions of animals and deals with other aspects of animal health."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Veterinarian, General"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/06520> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/065> ;
    schema:codeValue 6520,
        "0-65.20"^^xsd:string ;
    schema:description "Exercises surveillance of quality, purity and safety of food of animal origin intended for human consumption and investigates and controls animal diseases hazardous to man."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Public Health Veterinarian"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/06590> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/065> ;
    schema:codeValue 6590,
        "0-65.90"^^xsd:string ;
    schema:description "This group includes veterinarians not elsewhere classified, for example those controlling import and export of animals and animal products; controlling drugs and vaccines used in veterinary practise; advising on the breeding, transport, care and health problems of laboratory animals; advising on and assisting in epidemiological and other surveillance of zoonoses; collaborating in the preparation of animals for space exploration experiments."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Other Veterinarians"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/06610> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/066> ;
    schema:codeValue 6610,
        "0-66.10"^^xsd:string ;
    schema:description "Carries out, but only to a limited extent, diagnostic, preventive and curative veterinary duties as described under Veterinarian, general (0-65.10), more particularly as regards common diseases and disorders of animals, either independently or under the general direction of fully qualified veterinarian. The workers in this group have not had the full training of Veterinarians (0-65)."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Veterinary Assistant"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/06710> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/067> ;
    schema:codeValue 6710,
        "0-67.10"^^xsd:string ;
    schema:description "Makes and dispenses medicaments and related preparations according to prescriptions or formulae."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Pharmacist"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/06810> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/068> ;
    schema:codeValue 6810,
        "0-68.10"^^xsd:string ;
    schema:description "Assists in a pharmacy, hospital or dispensary to make and dispense medicaments, under the direction of a pharmacist."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Pharmaceutical Assistant"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/06910> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/069> ;
    schema:codeValue 6910,
        "0-69.10"^^xsd:string ;
    schema:description "Plans and supervises the preparation of therapeutic or other diets for individuals or for groups in hospitals, institutions and other establishments and for workers in particular sectors; gives instruction in selection and proper preparation of food according to dietetic principles; performs duties related to nutrition programmes."@en ;
    schema:inCodeSet <https://iisg.amsterdam/resource/hisco/HISCO> ;
    schema:name "Dietitian, General"@en-gb .

<https://iisg.amsterdam/resource/hisco/code/hisco/06920> a <https://iisg.amsterdam/resource/hisco/MicroGroup>,
        schema:CategoryCode ;
    rdfs:subClassOf <https://iisg.amsterdam/resource/hisco/code/hisco/069> ;
    schema:codeValue 6920,
        "0-69.20"^^xsd:string ;
